# .env.example
# Copy to .env for local development

ENVIRONMENT=local
TENANT_ID=curry_bowl_express

AWS_REGION=us-west-2
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# FLOCI Runtime
FLOCI_ENDPOINT=http://localhost:4566
EKS_CLUSTER_NAME=fip-local-eks
MSK_CLUSTER_NAME=fip-local-msk

# This value is overwritten by Terraform output after MSK is created.
# FLOCI may return an internal Docker broker IP such as 172.17.0.4:9092.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Buckets
RAW_BUCKET=fip-local-raw
PROCESSED_BUCKET=fip-local-processed
ARTIFACTS_BUCKET=fip-local-artifacts

# Secrets Manager paths
OPENAI_SECRET_ID=/feedback/local/openai_api_key
JWT_SECRET_ID=/feedback/local/jwt_secret
DB_PASSWORD_SECRET_ID=/feedback/local/db_password